menuconfig MESHTASTIC
	bool "Meshtastic mesh radio stack [EXPERIMENTAL]"
	depends on ZEPHYR_NANOPB_MODULE
	select LORA
	select NANOPB
	select PSA_CRYPTO
	select PSA_WANT_ALG_CTR
	select PSA_WANT_KEY_TYPE_AES
	select EXPERIMENTAL
	help
	  Enable the Meshtastic mesh radio stack.

	  Provides a wire-compatible implementation of the Meshtastic protocol
	  (https://meshtastic.org) on top of the Zephyr raw LoRa driver API.
	  Supports text messaging (PortNum 1) and raw data delivery over the
	  LongFast channel parameters (SF 11, BW 250 kHz, CR 4/5).

	  Requires a LoRa transceiver supported by the Zephyr LoRa driver
	  (e.g. SX1276, SX1262) and the nanopb module in the west workspace.

if MESHTASTIC

config MESHTASTIC_PHONEAPI
	bool "Phone-app (client) API core"
	help
	  Client-facing FromRadio/ToRadio protocol core shared by the BLE, serial
	  and TCP transports. Normally selected automatically by whichever
	  transport is enabled; can also be turned on directly for a custom
	  transport or for host-side tests.

config MESHTASTIC_ADMIN
	bool "Handle AdminMessage config-write from the connected app"
	depends on MESHTASTIC_PHONEAPI
	select REBOOT
	default y
	help
	  Allow the directly-connected client app (BLE/serial/TCP) to WRITE
	  settings via AdminMessage (portnum ADMIN_APP), not just read them.
	  Handles get_/set_ config, module config, channels and owner,
	  begin/commit edit transactions, and reboot. Local (from == this node)
	  admin only — no session-passkey validation, PKC, or remote/mesh admin.
	  Persistence of writes across reboot additionally requires
	  MESHTASTIC_SETTINGS; without it writes apply live but are RAM-only.

menuconfig MESHTASTIC_SETTINGS
	bool "Persist Meshtastic configuration with Zephyr settings"
	select SETTINGS
	help
	  Store Meshtastic owner, channel, config and module settings through
	  Zephyr's settings subsystem. The selected settings backend remains
	  controlled by the application or board configuration.

if MESHTASTIC_SETTINGS

config MESHTASTIC_SETTINGS_SAVE_DELAY_MS
	int "Meshtastic settings save delay (ms)"
	default 1000
	range 0 60000
	help
	  Delay used to coalesce runtime configuration changes before saving
	  the Meshtastic settings subtree.

endif # MESHTASTIC_SETTINGS

module = MESHTASTIC
module-str = meshtastic
source "subsys/logging/Kconfig.template.log_config"

rsource "Kconfig.core"
rsource "Kconfig.nodedb"
rsource "Kconfig.nodeinfo"
rsource "Kconfig.message"
rsource "Kconfig.traceroute"
rsource "Kconfig.reliable"
rsource "Kconfig.ble"
rsource "Kconfig.serial"
rsource "Kconfig.tcp"
rsource "Kconfig.shell"
rsource "Kconfig.position"
rsource "Kconfig.gnss"
rsource "Kconfig.device_metrics"
rsource "Kconfig.airtime"
rsource "Kconfig.environment_metrics"
rsource "Kconfig.telemetry"
rsource "Kconfig.mqtt"
rsource "Kconfig.wifi_auto"
rsource "Kconfig.sntp"
rsource "Kconfig.pki"
rsource "Kconfig.ota"

menu "LoRa transmit retry"

config MESHTASTIC_TX_BUSY_RETRIES
	int "Retries when CAD reports busy channel"
	range 0 32
	default 6
	help
	  Number of retransmission attempts when lora_send() returns -EBUSY
	  because CAD/LBT detected channel activity.

config MESHTASTIC_TX_BUSY_BACKOFF_MIN_MS
	int "Minimum backoff on busy channel (ms)"
	range 0 60000
	default 8
	help
	  Minimum randomized wait in milliseconds between retry attempts when
	  the channel is busy.

config MESHTASTIC_TX_BUSY_BACKOFF_MAX_MS
	int "Maximum backoff on busy channel (ms)"
	range 0 60000
	default 40
	help
	  Maximum randomized wait in milliseconds between retry attempts when
	  the channel is busy.
	  If this is less than the minimum, the minimum value is used.

endmenu

endif # MESHTASTIC
