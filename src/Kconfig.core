menu "Meshtastic core"

config MESHTASTIC_THREAD_STACK_SIZE
	int "Processing thread stack size (bytes)"
	default 8192 if MESHTASTIC_BLE
	default 6144 if MESHTASTIC_GNSS || MESHTASTIC_DEVICE_METRICS || \
		MESHTASTIC_ENVIRONMENT_METRICS || MESHTASTIC_NODEINFO
	default 4096
	help
	  Stack size for the Meshtastic packet-processing thread.  Must
	  accommodate nanopb decoding, PSA crypto and the relay/auto-reply
	  transmit path.  Increase if stack overflows are observed.

config MESHTASTIC_THREAD_PRIORITY
	int "Processing thread priority"
	default 7
	help
	  Cooperative (negative) or preemptive (non-negative) priority of the
	  Meshtastic packet-processing thread.

config MESHTASTIC_RX_QUEUE_DEPTH
	int "Receive hand-off queue depth (frames)"
	default 4
	range 2 16
	help
	  Number of raw LoRa frames buffered between the driver receive
	  callback and the processing thread.  Each slot consumes about
	  260 bytes of RAM.  Increase if rx_dropped climbs under bursty
	  traffic (the processing thread fell behind incoming packets).

config MESHTASTIC_RX_REARM_RETRY_MS
	int "Receive re-arm retry interval (ms)"
	default 1000
	help
	  If re-arming continuous receive after a transmit fails, the radio
	  is left deaf.  The processing thread retries the re-arm at this
	  interval until it succeeds.

config MESHTASTIC_OUTBOUND_QUEUE_MAX
	int "Outbound LoRa transmit queue capacity (frames)"
	default 16
	range 2 64
	help
	  Physical capacity of the outbound priority queue. The scheduler
	  (meshtastic sched) enforces a runtime soft depth <= this ceiling, so
	  the depth can be tuned live without a rebuild up to this maximum. Each
	  slot holds a full wire frame, so raising this costs RAM.

config MESHTASTIC_OUTBOUND_QUEUE_DEPTH
	int "Default outbound transmit soft depth (frames)"
	default 8
	range 2 64
	help
	  Default runtime soft depth of the outbound queue (the scheduler's
	  starting tx.depth). Must be <= MESHTASTIC_OUTBOUND_QUEUE_MAX. All LoRa
	  TX (application packets, relay, periodic telemetry) is serialized
	  through this queue.

config MESHTASTIC_OUTBOUND_STACK_SIZE
	int "Outbound transmit worker stack size (bytes)"
	default 2048
	help
	  Stack for the thread that performs serialized LoRa transmits.

config MESHTASTIC_PACKET_HEXDUMP
	bool "Hex dump LoRa wire packets at DBG log level"
	default MESHTASTIC_LOG_LEVEL_DBG
	help
	  When enabled and the meshtastic log level is DBG, log a hex dump of
	  each Meshtastic wire packet (16-byte header plus encrypted payload)
	  on transmit and receive.

config MESHTASTIC_DEFAULT_HOP_LIMIT
	int "Default hop limit for outgoing packets"
	default 3
	range 1 7
	help
	  Number of times an outgoing packet may be relayed by intermediate
	  nodes.  3 is the Meshtastic firmware default; higher values increase
	  range at the cost of additional channel utilisation.

config MESHTASTIC_DEFAULT_REGION
	int "Default LoRa region code"
	default 1
	range 0 24
	help
	  Region this device operates in, as a meshtastic_Config_LoRaConfig_RegionCode
	  value.  1 is US (902-928 MHz) and is the default.  Seeds the stored
	  config on first boot; a later admin or phone-app change overrides it.

	  THIS IS A REGULATORY SETTING.  It determines the frequency the radio
	  transmits on and the power limit applied.  Set it to the region you are
	  physically operating in — transmitting outside your allocation is
	  illegal in most jurisdictions, and the firmware cannot detect that for
	  you.

	  Common values: 1 US, 2 EU_433, 3 EU_868, 4 CN, 5 JP, 6 ANZ, 7 RU,
	  8 KR, 9 TW, 10 IN, 11 NZ_865, 12 TH.  See the RegionCode enum in
	  meshtastic/config.proto for the full list.

	  Rejected regions:

	  - Amateur (ITU) allocations, whether or not the owner record is marked
	    licensed.  Amateur service forbids obscuring the meaning of a
	    transmission, and this port does not yet disable encryption in
	    licensed mode the way the reference firmware does.  Separately, the
	    2 m allocations (144-146 MHz) are below the SX1262's 150 MHz tuning
	    floor, and the 125 cm / 70 cm allocations fall far outside the
	    supported boards' 863-928 MHz front end.

	  - LORA_24 (2.4 GHz): no wide-LoRa radio support in this port.

	  A US device needs no licence: 902-928 MHz is unlicensed ISM spectrum.

config MESHTASTIC_DEFAULT_OK_TO_MQTT
	bool "Consent to our traffic being republished to MQTT by default"
	default n
	help
	  Seeds config.lora.config_ok_to_mqtt on first boot. When set, every
	  packet this node originates carries the OK_TO_MQTT bit, telling any
	  gateway that hears it that our traffic may be republished to an MQTT
	  broker — including a public one.

	  Defaults to n, matching the reference firmware: consent to being
	  rebroadcast off the local RF mesh should be opt-in.

	  This governs only OUR OWN traffic. Whether this node republishes other
	  people's packets is a separate matter, decided by their bit and by
	  whether the configured broker is private.

	  A later admin or phone-app change overrides this seed.

config MESHTASTIC_TX_POWER
	int "Default TX power (dBm)"
	default 17
	help
	  Default LoRa transmit power used when meshtastic_config.tx_power is
	  zero.  Most LoRa modules support 2–20 dBm; consult your hardware
	  datasheet for the allowed range.

config MESHTASTIC_DUP_CACHE_SIZE
	int "Duplicate-packet cache size (entries)"
	default 32
	range 4 64
	help
	  Number of (src, packet_id) pairs retained for duplicate suppression.
	  Each entry consumes 12 bytes of RAM.  Increase if duplicate packets
	  are observed in dense mesh deployments.  The retention window is bounded
	  by both this size and the runtime "dedup.ttl" scheduler knob (an entry
	  older than the TTL no longer suppresses a re-sent packet).

config MESHTASTIC_NODE_LONG_NAME
	string "Default node long name"
	default "Zephyr Meshtastic"
	help
	  Human-readable node name used when meshtastic_config.long_name is
	  NULL. This is reported through local APIs such as Bluetooth PhoneAPI.

config MESHTASTIC_NODE_SHORT_NAME
	string "Default node short name"
	default "ZEPH"
	help
	  Short node name used when meshtastic_config.short_name is NULL.

choice MESHTASTIC_NODE_ID_SOURCE
	prompt "Node ID source"
	default MESHTASTIC_NODE_ID_HWINFO if HWINFO_HAS_DRIVER
	default MESHTASTIC_NODE_ID_CUSTOM
	help
	  How the local 32-bit Meshtastic node ID is determined at init time.

config MESHTASTIC_NODE_ID_HWINFO
	bool "HWINFO device ID"
	depends on HWINFO_HAS_DRIVER
	help
	  Derive the node ID from the last four bytes of the value returned by
	  hwinfo_get_device_id().  Requires CONFIG_HWINFO.

#config MESHTASTIC_NODE_ID_BT_MAC
#	bool "Bluetooth identity address"
#	depends on BT
#	help
#	  Derive the node ID from the last four bytes of the default Bluetooth
#	  identity address (bt_id_get).
#
#config MESHTASTIC_NODE_ID_WIFI_MAC
#	bool "Wi-Fi link-layer address"
#	depends on NET_IF
#	help
#	  Derive the node ID from the last four bytes of the default network
#	  interface link-layer address.

config MESHTASTIC_NODE_ID_CUSTOM
	bool "Custom fixed value"
	help
	  Use meshtastic_config.node_id when non-zero, otherwise
	  CONFIG_MESHTASTIC_NODE_ID_DEFAULT.

endchoice

config MESHTASTIC_NODE_ID_DEFAULT
	hex "Default node ID (custom source)"
	depends on MESHTASTIC_NODE_ID_CUSTOM
	default 0xDEADBEEF
	help
	  Node ID used when MESHTASTIC_NODE_ID_CUSTOM is selected and
	  meshtastic_config.node_id is zero.

endmenu
